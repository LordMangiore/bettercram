    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/push-notifications": "^8.0.3",
    "@elevenlabs/client": "^0.15.2",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@mendable/firecrawl-js": "^4.16.0",
    "@netlify/blobs": "^10.7.4",
    "@netlify/functions": "^5.1.5",
    "canvas-confetti": "^1.9.4",
    "dompurify": "^3.3.3",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.44",
    "pdf-parse": "^1.1.1",
