{
  "name": "flashcard-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node -e \"const fs=require('fs');const f='public/sw.js';let s=fs.readFileSync(f,'utf8');s=s.replace(/bettercram-[^']+/,'bettercram-'+Date.now());fs.writeFileSync(f,s)\" && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
